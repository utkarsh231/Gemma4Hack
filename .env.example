# Required for live Gemma calls through the Gemini API.
GEMINI_API_KEY=

# Optional. Enables recommended YouTube videos alongside generated notes.
YOUTUBE_API_KEY=
YOUTUBE_MAX_VIDEOS=4

# Required for FastAPI to verify Supabase Auth bearer tokens.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=
# Hosted Gemma 4 models currently documented for the Gemini API:
# - gemma-4-26b-a4b-it: lower latency / production-friendly default
# - gemma-4-31b-it: larger model for quality-heavy runs
GEMMA_MODEL=gemma-4-26b-a4b-it

# Required for RAG chat through Pinecone integrated embeddings.
PINECONE_API_KEY=
PINECONE_INDEX_NAME=gemma4hack-study-chunks
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1
PINECONE_EMBEDDING_MODEL=llama-text-embed-v2
RAG_TOP_K=5
RAG_KEYWORD_TOP_K=4
RAG_SEMANTIC_TIMEOUT_SECONDS=8
RAG_CHUNK_CHARS=1800
RAG_CHUNK_OVERLAP_CHARS=250

APP_ENV=local
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=25
MAX_PDF_PAGES=80
MAX_EXTRACTED_CHARS=120000
